# ace-ears configuration — copy to ".env" and fill in.
# (.env is git-ignored. Only the words/prosody half needs a key;
#  the acoustic half is always local and free.)

# Which speech-to-text backend to use: inworld | elevenlabs | local
# - inworld    : richest — also returns a VOICE profile (style/emotion/age/accent). Recommended.
# - elevenlabs : transcript + word timestamps (+ audio-event tags). No voice profile.
# - local      : fully offline via faster-whisper. No key, no upload. No voice profile.
STT_PROVIDER=inworld

# --- Inworld (STT_PROVIDER=inworld) ---
# Base64 "Basic" auth key from console.inworld.ai
INWORLD_API_KEY=
# ...or instead of the key above, point at a file that holds it:
# INWORLD_KEY_PATH=/path/to/keyfile

# --- ElevenLabs (STT_PROVIDER=elevenlabs) ---
ELEVENLABS_API_KEY=

# --- Local Whisper (STT_PROVIDER=local) ---
# pip install faster-whisper   (and ffmpeg on PATH)
WHISPER_MODEL=base
# WHISPER_DEVICE=auto      # auto | cpu | cuda
# WHISPER_COMPUTE=auto     # auto | int8 | float16 | float32
